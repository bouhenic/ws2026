# ── API ──────────────────────────────────────
PORT=3000
# Clé d'authentification de l'API (header X-API-Key).
# Générer avec : openssl rand -hex 32
API_KEY=changeme

# ── MQTT / The Things Network ────────────────
MQTT_URL=mqtts://eu1.cloud.thethings.network:8883
MQTT_USERNAME=ws-clichy@ttn
# Clé API TTN (à régénérer sur la console TTN, l'ancienne a fuité dans le code)
MQTT_PASSWORD=NNSXS.XXXXXXXX
# Topic ciblé : uniquement les uplinks de l'application
MQTT_TOPIC=v3/ws-clichy@ttn/devices/+/up

# ── InfluxDB ─────────────────────────────────
# En local (hors docker) : http://localhost:8086
# Dans docker-compose, l'API utilise automatiquement http://influxdb:8086
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=changeme-token
INFLUX_ORG=cielnewton
INFLUX_BUCKET=ws2026
# Identifiants d'init du conteneur InfluxDB (premier démarrage uniquement)
INFLUX_USERNAME=admin
INFLUX_PASSWORD=changeme-password

# ── Déploiement ──────────────────────────────
# Propriétaire GitHub des images GHCR (en minuscules)
GHCR_OWNER=mon-compte-github
# Domaine public servi par nginx
DOMAIN=weatherstation.cielnewton.fr
# Email pour Let's Encrypt
LETSENCRYPT_EMAIL=sbouhenic@gmail.com
